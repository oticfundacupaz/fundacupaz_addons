<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista del wizard de reporte -->
    <record id="view_reporte_asistencia_wizard_form" model="ir.ui.view">
        <field name="name">reporte.asistencia.wizard.form</field>
        <field name="model">reporte.asistencia.wizard</field>
        <field name="arch" type="xml">
            <form string="Generar Reporte de Asistencias">
                <sheet>
                    <group string="Filtros del Reporte">
                        <group col="2">
                            <field name="fecha_desde" string="Fecha Desde"/>
                            <field name="fecha_hasta" string="Fecha Hasta"/>
                        </group>
                        <group col="2">
                            <field name="department_id" string="Departamento"
                                   options="{'no_create': True}"
                                   placeholder="Todos los departamentos"/>
                            <field name="agrupar_por_departamento" string="Agrupar por Departamento"/>
                        </group>
                        <group col="1">
                            <field name="employee_ids" string="Empleados Específicos"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"
                                   placeholder="Dejar vacío para incluir todos"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_generar_reporte" string="📄 Generar PDF"
                            type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
