<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View Form -->
    <record id="view_benefits_report_wizard_form" model="ir.ui.view">
        <field name="name">benefits.report.wizard.form</field>
        <field name="model">benefits.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Reporte de Entrega de Beneficios">
                <sheet>
                    <group>
                        <field name="report_type" widget="radio"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print_report" string="Imprimir PDF" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_benefits_report_wizard" model="ir.actions.act_window">
        <field name="name">Entrega de Beneficios</field>
        <field name="res_model">benefits.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu Item (In Employees / Reporting) -->
    <menuitem id="menu_benefits_report"
              name="Entrega de beneficios"
              parent="hr.hr_menu_hr_reports"
              action="action_benefits_report_wizard"
              sequence="100"/>
</odoo>
